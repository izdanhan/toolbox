#!/usr/bin/env bash

# Uses clean Nerd Font glyphs: Network (箚뼦), Audio (箚빢), Bluetooth (箚궚)
options="箚뼦 Network (nmtui)\n箚빢 Audio Mixer (wiremix)\n箚궚 Bluetooth (bluetui)"

choice=$(echo -e "$options" | rofi -dmenu -p "System Config" -theme-str 'window { width: 320px; height: 180px; font: "JetBrainsMono Nerd Font 11"; }')

case "$choice" in
    *"Network"*)
        kitty --class floating_tui -e nmtui
        ;;
    *"Audio"*)
        kitty --class floating_tui -e wiremix
        ;;
    *"Bluetooth"*)
        kitty --class floating_tui -e bluetui
        ;;
esac
