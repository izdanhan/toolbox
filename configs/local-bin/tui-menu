#!/usr/bin/env bash

# Uses clean Nerd Font glyphs: Network (ó°–©), Audio (ó°•¾), Bluetooth (ó°‚¯), Config Files (ó±”—)
options="ó°•¾ Audio Mixer (wiremix)\nó°‚¯ Bluetooth (bluetui)\nó°–© Network (nmtui)\nó±”— Hyprland Config\nó±”— Kitty Config"

# Kept strictly on one line to prevent Rofi parser errors
choice=$(echo -e "$options" | rofi -dmenu -p "System Config" -theme-str 'window { width: 320px; height: 160px; font: "JetBrainsMono Nerd Font 11"; } inputbar { enabled: false; } listview { scrollbar: false; }')

case "$choice" in
    *"Audio"*)
        kitty --class floating_tui -e wiremix
        ;;
    *"Bluetooth"*)
        kitty --class floating_tui -e bluetui
        ;;
    *"Network"*)
        kitty --class floating_tui -e nmtui
        ;;
    *"Hyprland"*)
        kitty -e fresh ~/.config/hypr/hyprland.lua
        ;;
    *"Kitty"*)
        kitty -e fresh ~/.config/kitty/kitty.conf
        ;;        
esac
