#!/bin/bash
echo "=== Starting Ollama with Vulkan (no ROCm) ==="

sudo systemctl stop ollama 2>/dev/null || true
sudo systemctl set-environment OLLAMA_VULKAN=1
sudo systemctl set-environment OLLAMA_FLASH_ATTENTION=1
sudo systemctl set-environment OLLAMA_LLM_LIBRARY=libggml-vulkan.so

sudo systemctl start ollama
sleep 4

echo "=== Starting Open WebUI ==="
podman stop open-webui 2>/dev/null || true
podman rm open-webui 2>/dev/null || true

podman run -d \
  --name open-webui \
  --network=host \
  -v open-webui:/app/backend/data \
  -e OLLAMA_BASE_URL=http://127.0.0.1:11434 \
  --restart unless-stopped \
  ghcr.io/open-webui/open-webui:main

echo "✅ Started!"
echo "→ Open WebUI → http://localhost:8080"
