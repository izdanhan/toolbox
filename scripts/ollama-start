#!/bin/bash
# start-ollama-webui - Reliable version for Podman on Fedora

echo "=== Starting Ollama with Vulkan ==="
sudo systemctl set-environment OLLAMA_VULKAN=1
sudo systemctl start ollama
sleep 4

echo "=== Starting Open WebUI (Podman + host network) ==="

podman stop open-webui 2>/dev/null || true
podman rm open-webui 2>/dev/null || true

podman run -d \
  --name open-webui \
  --network=host \
  -v open-webui:/app/backend/data \
  -e OLLAMA_BASE_URL=http://127.0.0.1:11434 \
  --restart unless-stopped \
  ghcr.io/open-webui/open-webui:main

echo "✅ Ollama + Open WebUI started successfully!"
echo "→ Open WebUI: http://localhost:8080"
echo "→ Ollama API: http://localhost:11434"
